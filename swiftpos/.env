# =============================================================================
# SwiftPOS Environment Configuration
# =============================================================================
# IMPORTANT: These environment variables MUST be set before running the app
# Copy this file to .env.local and fill in the values
# DO NOT commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# NeonDB connection string
# Format: postgresql://username:password@host/database?options
DATABASE_URL="postgresql://username:password@host/database"

# -----------------------------------------------------------------------------
# JWT Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# JWT secret key - MUST be at least 32 characters
# Generate a secure random string for production
JWT_SECRET="generate-a-secure-random-string-at-least-32-chars"

# JWT token expiry in hours (optional, default: 24)
JWT_EXPIRY_HOURS=24

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="SwiftPOS"
APP_VERSION="1.0.0"
LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# Neon Auth Configuration (Optional - for future use)
# -----------------------------------------------------------------------------
# If you want to use Neon Auth for web-based authentication:
# 1. Create a Neon project with Neon Auth enabled
# 2. Get your credentials from the Neon dashboard
# 3. Uncomment and fill in the values below
#
# NEON_AUTH_PROJECT_ID=""
# NEON_AUTH_PUBLISHABLE_CLIENT_KEY=""
# STACK_SECRET_SERVER_KEY=""
