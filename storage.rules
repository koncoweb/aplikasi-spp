rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /school/logo.{extension} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.resource.size < 2 * 1024 * 1024 // 2MB max
                   && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
} 